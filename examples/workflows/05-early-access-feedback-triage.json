    "nodes": [
        {
            "id": "trigger_1",
            "type": "trigger",
            "position": {
                "x": 520,
                "y": 60
            },
            "data": {
                "label": "User Message",
                "triggerType": "user_message"
            }
        },
        {
            "id": "msg_intro",
            "type": "sendMessage",
            "position": {
                "x": 520,
                "y": 200
            },
            "data": {
                "label": "Set Expectations",
                "messageType": "text",
                "messageContent": "Thanks for trying our Early Access product. I can collect bug reports, feature requests, docs/setup issues, or general product feedback in a structured way so the team can act on it."
            }
        },
        {
            "id": "input_feedback_type",
            "type": "collectInput",
            "position": {
                "x": 520,
                "y": 340
            },
            "data": {
                "label": "Choose Feedback Type",
                "prompt": "What kind of feedback is this?",
                "variableName": "feedback_type",
                "inputType": "choice",
                "choices": "Bug report,Feature request,Docs/setup issue,General product feedback",
                "required": true
            }
        },
        {
            "id": "input_feedback_title",
            "type": "collectInput",
            "position": {
                "x": 520,
                "y": 480
            },
            "data": {
                "label": "Capture Short Title",
                "prompt": "Give your feedback a short title so the team can recognize it quickly.",
                "variableName": "feedback_title",
                "inputType": "text",
                "required": true
            }
        },
        {
            "id": "input_feedback_detail",
            "type": "collectInput",
            "position": {
                "x": 520,
                "y": 620
            },
            "data": {
                "label": "Capture Full Detail",
                "prompt": "Describe the issue, request, or feedback in as much detail as you can.",
                "variableName": "feedback_detail",
                "inputType": "text",
                "required": true
            }
        },
        {
            "id": "input_impact",
            "type": "collectInput",
            "position": {
                "x": 520,
                "y": 760
            },
            "data": {
                "label": "Capture Impact",
                "prompt": "How much impact does this have right now?",
                "variableName": "impact_level",
                "inputType": "choice",
                "choices": "Low - minor annoyance,Medium - slows me down,High - blocks a task,Critical - production risk",
                "required": true
            }
        },
        {
            "id": "switch_feedback_type",
            "type": "switchRouter",
            "position": {
                "x": 520,
                "y": 920
            },
            "data": {
                "label": "Route By Feedback Type",
                "switchValue": "{{feedback_type}}",
                "cases": "[{\"case\":\"Bug report\",\"label\":\"Bug\"},{\"case\":\"Feature request\",\"label\":\"Feature\"},{\"case\":\"Docs/setup issue\",\"label\":\"Docs\"}]",
                "defaultLabel": "General"
            }
        },
        {
            "id": "bug_expected",
            "type": "collectInput",
            "position": {
                "x": 40,
                "y": 1080
            },
            "data": {
                "label": "Expected Behavior",
                "prompt": "What did you expect to happen?",
                "variableName": "expected_behavior",
                "inputType": "text",
                "required": true
            }
        },
        {
            "id": "bug_actual",
            "type": "collectInput",
            "position": {
                "x": 40,
                "y": 1220
            },
            "data": {
                "label": "Actual Behavior",
                "prompt": "What happened instead?",
                "variableName": "actual_behavior",
                "inputType": "text",
                "required": true
            }
        },
        {
            "id": "bug_steps",
            "type": "collectInput",
            "position": {
                "x": 40,
                "y": 1360
            },
            "data": {
                "label": "Reproduction Steps",
                "prompt": "How can someone reproduce this? Share the shortest reliable steps you know.",
                "variableName": "reproduce_steps",
                "inputType": "text",
                "required": true
            }
        },
        {
            "id": "bug_environment",
            "type": "collectInput",
            "position": {
                "x": 40,
                "y": 1500
            },
            "data": {
                "label": "Environment",
                "prompt": "Where did this happen?",
                "variableName": "bug_environment",
                "inputType": "choice",
                "choices": "Sandbox demo,Local install,Staging app,Production app",
                "required": true
            }
        },
        {
            "id": "set_bug_case_details",
            "type": "setVariable",
            "position": {
                "x": 40,
                "y": 1640
            },
            "data": {
                "label": "Build Bug Detail Summary",
                "variableName": "case_details",
                "expression": "Environment: {{bug_environment}}\nExpected: {{expected_behavior}}\nActual: {{actual_behavior}}\nRepro steps: {{reproduce_steps}}"
            }
        },
        {
            "id": "set_bug_type",
            "type": "setVariable",
            "position": {
                "x": 40,
                "y": 1780
            },
            "data": {
                "label": "Normalize Bug Type",
                "variableName": "submission_type",
                "expression": "bug_report"
            }
        },
        {
            "id": "feature_outcome",
            "type": "collectInput",
            "position": {
                "x": 320,
                "y": 1080
            },
            "data": {
                "label": "Desired Outcome",
                "prompt": "What should the product help you do that it cannot do well enough today?",
                "variableName": "desired_outcome",
                "inputType": "text",
                "required": true
            }
        },
        {
            "id": "feature_workaround",
            "type": "collectInput",
            "position": {
                "x": 320,
                "y": 1220
            },
            "data": {
                "label": "Current Workaround",
                "prompt": "What is your current workaround, if any?",
                "variableName": "current_workaround",
                "inputType": "text",
                "required": true
            }
        },
        {
            "id": "feature_use_case",
            "type": "collectInput",
            "position": {
                "x": 320,
                "y": 1360
            },
            "data": {
                "label": "Use Case Context",
                "prompt": "What real-world use case or workflow is this request for?",
                "variableName": "use_case_context",
                "inputType": "text",
                "required": true
            }
        },
        {
            "id": "set_feature_case_details",
            "type": "setVariable",
            "position": {
                "x": 320,
                "y": 1500
            },
            "data": {
                "label": "Build Feature Detail Summary",
                "variableName": "case_details",
                "expression": "Desired outcome: {{desired_outcome}}\nCurrent workaround: {{current_workaround}}\nUse case: {{use_case_context}}"
            }
        },
        {
            "id": "set_feature_type",
            "type": "setVariable",
            "position": {
                "x": 320,
                "y": 1640
            },
            "data": {
                "label": "Normalize Feature Type",
                "variableName": "submission_type",
                "expression": "feature_request"
            }
        },
        {
            "id": "kb_docs",
            "type": "knowledgeBase",
            "position": {
                "x": 620,
                "y": 1080
            },
            "data": {
                "label": "Search Docs Context",
                "query": "{{feedback_title}} {{feedback_detail}}",
                "topK": 6,
                "minSimilarity": 0.6,
                "outputVariable": "kb_docs_context"
            }
        },
        {
            "id": "ai_docs_coverage",
            "type": "aiAgent",
            "position": {
                "x": 620,
                "y": 1220
            },
            "data": {
                "label": "Check Docs Coverage",
                "provider": "",
                "model": "",
                "systemPrompt": "You are deciding whether the existing docs already contain enough information to help the user. Respond with exactly one lowercase word: covered or gap.",
                "userPromptTemplate": "Issue title: {{feedback_title}}\nIssue detail: {{feedback_detail}}\n\nDocs context:\n{{kb_docs_context}}",
                "temperature": 0,
                "maxTokens": 10,
                "outputVariable": "docs_coverage",
                "streamToChat": false
            }
        },
        {
            "id": "cond_docs_covered",
            "type": "condition",
            "position": {
                "x": 620,
                "y": 1360
            },
            "data": {
                "label": "Docs Already Cover This?",
                "leftOperand": "{{docs_coverage}}",
                "operator": "contains",
                "rightOperand": "covered"
            }
        },
        {
            "id": "ai_docs_answer",
            "type": "aiAgent",
            "position": {
                "x": 460,
                "y": 1500
            },
            "data": {
                "label": "Draft Docs Answer",
                "provider": "",
                "model": "",
                "systemPrompt": "You are a product docs assistant. Use the docs context to answer the user's setup or documentation issue with the shortest actionable answer you can. If the context is partial, say that clearly and still help. End by saying you will also log the feedback for the team.",
                "userPromptTemplate": "Docs context:\n{{kb_docs_context}}\n\nIssue title: {{feedback_title}}\nIssue detail: {{feedback_detail}}",
                "temperature": 0.2,
                "maxTokens": 500,
                "outputVariable": "docs_answer",
                "streamToChat": true
            }
        },
        {
            "id": "input_docs_resolution",
            "type": "collectInput",
            "position": {
                "x": 460,
                "y": 1660
            },
            "data": {
                "label": "Docs Resolution Status",
                "prompt": "Did that answer solve the issue?",
                "variableName": "docs_resolution_status",
                "inputType": "choice",
                "choices": "Solved,Partly solved,Still blocked",
                "required": true
            }
        },
        {
            "id": "set_docs_case_details_yes",
            "type": "setVariable",
            "position": {
                "x": 460,
                "y": 1800
            },
            "data": {
                "label": "Build Covered Docs Summary",
                "variableName": "case_details",
                "expression": "Knowledge base coverage: covered\nResolution status: {{docs_resolution_status}}\nSuggested answer: {{docs_answer}}"
            }
        },
        {
            "id": "msg_docs_gap",
            "type": "sendMessage",
            "position": {
                "x": 820,
                "y": 1500
            },
            "data": {
                "label": "Explain Docs Gap",
                "messageType": "text",
                "messageContent": "I could not find a confident answer in the current docs, so I will log this as a docs/setup issue for the team."
            }
        },
        {
            "id": "set_docs_case_details_no",
            "type": "setVariable",
            "position": {
                "x": 820,
                "y": 1660
            },
            "data": {
                "label": "Build Docs Gap Summary",
                "variableName": "case_details",
                "expression": "Knowledge base coverage: gap\nResolution status: still_blocked\nSuggested answer: No confident match found in the knowledge base."
            }
        },
        {
            "id": "join_docs_case",
            "type": "join",
            "position": {
                "x": 620,
                "y": 1940
