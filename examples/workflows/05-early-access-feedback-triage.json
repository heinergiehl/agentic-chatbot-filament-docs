        {
            "id": "ai_operator_triage",
            "type": "aiAgent",
            "position": {
                "x": 520,
                "y": 3120
            },
            "data": {
                "label": "Create Internal Triage Note",
                "provider": "",
                "model": "",
                "systemPrompt": "You are preparing an internal product-ops note. Output exactly three lines and nothing else. Line 1: Priority: low | medium | high | critical. Line 2: Area: workflow editor | runtime | widget | docs/setup | AI quality | integration | other. Line 3: Summary: a concise actionable summary in at most 180 characters.",
                "userPromptTemplate": "Type: {{submission_type}}\nTitle: {{feedback_title}}\nDetail: {{feedback_detail}}\nImpact: {{impact_level}}\nCase details:\n{{case_details}}",
                "temperature": 0,
                "maxTokens": 120,
                "outputVariable": "operator_triage",
                "streamToChat": false
            }
        },
        {
            "id": "confirm_store_feedback",
            "type": "confirmation",
            "position": {
                "x": 520,
                "y": 3260
            },
            "data": {
                "label": "Review Before Storing",
                "prompt": "Store this feedback submission for review?",
                "variableName": "feedback_store_confirmed",
                "confirmLabel": "Store feedback",
                "cancelLabel": "Skip storing",
                "allowInterruptions": true,
                "interruptionPatterns": "",
                "semanticInterruptionCheck": true
            }
        },
        {
            "id": "action_store_feedback",
            "type": "action",
            "position": {
                "x": 520,
                "y": 3400
            },
            "data": {
                "label": "Store Structured Feedback",
                "actionKey": "store_submission",
                "inputMapping": "{\"schema_key\":\"feedback_form\",\"payload\":{\"feedback_type\":\"{{submission_type}}\",\"title\":\"{{feedback_title}}\",\"detail\":\"{{feedback_detail}}\",\"impact\":\"{{impact_level}}\",\"case_details\":\"{{case_details}}\",\"follow_up_permission\":\"{{follow_up_permission}}\",\"contact_email\":\"{{contact_email}}\",\"operator_triage\":\"{{operator_triage}}\"},\"meta\":{\"source\":\"workflow_example.early_access_feedback_triage\"}}",
                "outputVariable": "submission_result"
            }
        },
        {
            "id": "msg_store_cancelled",
            "type": "sendMessage",
            "position": {
                "x": 860,
                "y": 3400
            },
            "data": {
                "label": "Store Skipped",
                "messageType": "text",
                "messageContent": "No feedback record was stored. You can still ask another question or start again later."
            }
        },
        {
            "id": "msg_confirmation",
            "type": "sendMessage",
            "position": {
                "x": 520,
                "y": 3540
            },
            "data": {
                "label": "Confirm Submission",
                "messageType": "text",
                "messageContent": "Thanks. I've logged this as {{feedback_type}} for the team.\n\n{{followup_message}}\n\nEarly Access feedback like this directly shapes what we build next."
            }
        },
        {
            "id": "note_about",
            "type": "note",
            "position": {
                "x": 1180,
                "y": 80
            },
            "data": {
                "label": "About This Workflow",
                "noteContent": "Early Access Feedback Triage — Shows structured intake, per-type branching, docs self-service with KB + AI coverage check, shared AI operator triage, and schema-based submission capture. Requires a linked bot in query_and_write mode plus a feedback_form submission schema.",
                "color": "#f59e0b"
            }
        }
