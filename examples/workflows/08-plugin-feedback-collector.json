        {
            "id": "note_streaming_closure",
            "type": "note",
            "position": {
                "x": 900,
                "y": 2140
            },
            "data": {
                "label": "Streaming Demo",
                "noteContent": "This final AI step turns the structured bundle into a short streamed closing reply, so the workflow demonstrates deterministic prompts plus live token streaming in the same experience.",
                "color": "#bfdbfe"
            }
        },
        {
            "id": "trigger_1",
            "type": "trigger",
            "position": {
                "x": 520,
                "y": 60
            },
            "data": {
                "label": "User Message",
                "triggerType": "user_message"
            }
        },
        {
            "id": "msg_intro",
            "type": "sendMessage",
            "position": {
                "x": 520,
                "y": 200
            },
            "data": {
                "label": "Set Expectations",
                "messageType": "text",
                "messageContent": "I captured your message for the plugin team. I will classify it, save it, and then ask once for an optional follow-up email."
            }
        },
        {
            "id": "input_primary_detail",
            "type": "setVariable",
            "position": {
                "x": 520,
                "y": 340
            },
            "data": {
