                "variableName": "primary_feedback_detail",
                "expression": "{{input}}"
            }
        },
        {
            "id": "classify_feedback_type",
            "type": "intentClassifier",
            "position": {
                "x": 520,
                "y": 480
            },
            "data": {
                "label": "Classify Feedback",
                "variable": "classified_feedback_type",
                "inputTemplate": "{{primary_feedback_detail}}",
                "intents": [
                    {
                        "label": "Docs gap",
                        "description": "Missing, unclear, stale, or incomplete documentation."
                    },
                    {
                        "label": "UX frustration",
                        "description": "Confusing editor, widget, setup, navigation, or interaction experience."
                    },
                    {
                        "label": "Bug",
                        "description": "Broken behavior, errors, regressions, or incorrect runtime output."
                    },
                    {
                        "label": "Feature request",
                        "description": "A new capability, integration, setting, or enhancement request."
                    }
                ],
                "streamToChat": false
            }
        },
        {
            "id": "set_type_docs",
            "type": "setVariable",
            "position": {
                "x": 80,
