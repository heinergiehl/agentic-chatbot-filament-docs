            "type": "setVariable",
            "position": {
                "x": 520,
                "y": 1080
            },
            "data": {
                "label": "Build Single Item Summary",
                "variableName": "feedback_summary",
                "expression": "1. {{primary_feedback_type}}: {{primary_feedback_detail}}"
            }
        },
        {
            "id": "msg_email",
            "type": "sendMessage",
            "position": {
                "x": 520,
                "y": 1620
            },
            "data": {
                "label": "Ask For Email",
                "messageType": "buttons",
                "messageContent": "If you'd like a follow-up, send your email next. Otherwise tap Skip email or type skip.",
                "buttons": [
                    {
                        "label": "Skip email",
                        "value": "skip"
                    }
                ]
            }
        },
        {
            "id": "input_contact_email_raw",
            "type": "collectInput",
            "position": {
                "x": 520,
                "y": 1760
            },
            "data": {
                "label": "Collect Email",
                "prompt": "What's the best follow-up email? Type skip if you don't want to leave one.",
                "variableName": "contact_email_raw",
                "inputType": "text",
                "validation": "regex:/^(skip|no|no thanks|[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,})$/i",
                "required": true
            }
        },
        {
            "id": "cond_skip_email",
            "type": "condition",
            "position": {
                "x": 520,
                "y": 1900
            },
            "data": {
                "label": "Skip Email",
                "leftOperand": "{{contact_email_raw}}",
                "operator": "matches_regex",
                "rightOperand": "/^(skip|no|no thanks)$/i"
            }
        },
        {
            "id": "set_email_blank",
            "type": "setVariable",
            "position": {
                "x": 260,
                "y": 2040
            },
            "data": {
                "label": "Clear Email",
                "variableName": "contact_email",
                "expression": ""
            }
        },
        {
            "id": "set_email_value",
            "type": "setVariable",
            "position": {
                "x": 780,
                "y": 2040
            },
            "data": {
                "label": "Use Email",
                "variableName": "contact_email",
                "expression": "{{contact_email_raw}}"
            }
        },
        {
            "id": "join_contact_email",
            "type": "join",
            "position": {
                "x": 520,
                "y": 2180
            },
            "data": {
                "label": "Merge Contact Paths"
            }
        },
        {
            "id": "confirm_store_feedback_bundle",
            "type": "confirmation",
            "position": {
                "x": 520,
                "y": 2320
            },
            "data": {
                "label": "Review Before Storing",
                "prompt": "Store this feedback bundle for review?",
                "variableName": "feedback_bundle_store_confirmed",
                "confirmLabel": "Store feedback",
                "cancelLabel": "Skip storing",
                "allowInterruptions": true,
                "interruptionPatterns": "",
                "semanticInterruptionCheck": true
            }
        },
        {
            "id": "action_store_feedback_bundle",
            "type": "action",
            "position": {
                "x": 520,
                "y": 2460
            },
            "data": {
                "label": "Store Feedback Bundle",
                "actionKey": "store_submission",
                "inputMapping": {
                    "schema_key": "feedback_form",
                    "payload": {
                        "primary_feedback_type": "{{primary_feedback_type}}",
                        "primary_feedback_detail": "{{primary_feedback_detail}}",
                        "secondary_feedback_type": "{{secondary_feedback_type}}",
                        "secondary_feedback_detail": "{{secondary_feedback_detail}}",
                        "feedback_summary": "{{feedback_summary}}",
                        "contact_email": "{{contact_email}}"
                    },
                    "meta": {
                        "source": "workflow_example.plugin_feedback_collector"
                    }
                },
                "outputVariable": "stored_feedback"
            }
        },
        {
            "id": "msg_store_cancelled",
            "type": "sendMessage",
            "position": {
                "x": 820,
                "y": 2460
            },
            "data": {
                "label": "Store Skipped",
                "messageType": "text",
                "messageContent": "No feedback record was stored."
            }
        },
        {
            "id": "ai_close_feedback",
            "type": "aiAgent",
            "position": {
                "x": 520,
                "y": 2600
            },
            "data": {
                "label": "Draft Streamed Closing Reply",
                "systemPrompt": "You are the customer-facing feedback triage assistant for the Filament Agentic Chatbot plugin. Write exactly two short sentences in plain text. Sentence 1 must begin with \"Feedback saved.\" and briefly acknowledge the submitted feedback themes. Sentence 2 must begin with \"Follow-up:\" and clearly say whether the team can contact the user based on the provided email. Keep it under 60 words. No markdown, no bullets.",
                "userPromptTemplate": "Feedback summary:\n{{feedback_summary}}\n\nPrimary item: {{primary_feedback_type}}\nSecondary item: {{secondary_feedback_type}}\nFollow-up email: {{contact_email}}",
                "temperature": 0.2,
                "maxTokens": 120,
                "outputVariable": "closing_message",
                "streamToChat": true
            }
        }
    ],
