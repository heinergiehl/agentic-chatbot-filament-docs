            "data": {
                "label": "Welcome",
                "messageType": "text",
                "messageContent": "Welcome to Acme Support! How can I help you today?"
            }
        },
        {
            "id": "input_question",
            "type": "collectInput",
            "position": {
                "x": 400,
                "y": 340
            },
            "data": {
                "label": "Collect Question",
                "prompt": "Please describe your issue or question:",
                "variableName": "user_question",
                "inputType": "text",
                "required": true
            }
        },
        {
            "id": "kb_search",
            "type": "knowledgeBase",
            "position": {
                "x": 400,
                "y": 480
            },
            "data": {
                "label": "Search Support KB",
                "query": "{{user_question}}",
                "topK": 6,
                "minSimilarity": 0.6,
                "outputVariable": "kb_context"
            }
        },
        {
            "id": "ai_classify",
            "type": "aiAgent",
            "position": {
                "x": 400,
                "y": 640
            },
            "data": {
                "label": "Classify Intent",
                "provider": "",
                "model": "",
                "systemPrompt": "Classify the customer's question into exactly ONE category. Respond with a single lowercase word only: billing, technical, account, or general. No explanation.",
                "userPromptTemplate": "{{user_question}}",
                "temperature": 0,
                "maxTokens": 10,
                "outputVariable": "intent",
                "streamToChat": false
            }
        },
        {
            "id": "switch_intent",
            "type": "switchRouter",
            "position": {
                "x": 400,
                "y": 800
            },
            "data": {
                "label": "Route by Department",
                "switchValue": "{{intent}}",
                "cases": "[{\"case\": \"billing\", \"label\": \"Billing\"}, {\"case\": \"technical\", \"label\": \"Technical\"}, {\"case\": \"account\", \"label\": \"Account\"}]",
                "defaultLabel": "General"
            }
        },
        {
