                "userPromptTemplate": "Knowledge base context:\n{{kb_context}}\n\nCustomer question: {{user_question}}",
                "temperature": 0.5,
                "maxTokens": 1500,
                "outputVariable": "answer",
                "streamToChat": true
            }
        },
