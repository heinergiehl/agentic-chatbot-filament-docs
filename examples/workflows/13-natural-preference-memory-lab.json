      "sourceHandle": "case_1"
    },
    {
      "id": "e_recall_profile",
      "source": "classify_turn",
      "target": "has_profile_memory",
      "sourceHandle": "case_2"
    },
    {
      "id": "e_followup_rewrite",
      "source": "classify_turn",
      "target": "rewrite_followup_query",
      "sourceHandle": "case_3"
    },
    {
      "id": "e_direct_query",
      "source": "classify_turn",
      "target": "set_direct_query",
      "sourceHandle": "case_4"
    },
    {
      "id": "e_default_query",
      "source": "classify_turn",
      "target": "set_direct_query",
      "sourceHandle": "default"
    },
    {
      "id": "e_extract_valid",
      "source": "extract_profile_update",
      "target": "remember_profile_note",
      "sourceHandle": "valid"
    },
    {
      "id": "e_extract_invalid",
      "source": "extract_profile_update",
      "target": "remember_raw_profile_note",
      "sourceHandle": "invalid"
    },
    {
      "id": "e_remember_profile_context",
      "source": "remember_profile_note",
      "target": "build_profile_ack_context"
    },
    {
      "id": "e_remember_raw_profile_context",
      "source": "remember_raw_profile_note",
      "target": "build_profile_ack_context"
    },
    {
      "id": "e_profile_ack_answer",
      "source": "build_profile_ack_context",
      "target": "answer_profile_ack"
    },
    {
      "id": "e_has_profile_yes",
      "source": "has_profile_memory",
      "target": "build_profile_recall_context",
      "sourceHandle": "yes"
    },
    {
      "id": "e_has_profile_no",
      "source": "has_profile_memory",
      "target": "send_no_profile_memory",
      "sourceHandle": "no"
    },
    {
      "id": "e_recall_answer",
      "source": "build_profile_recall_context",
      "target": "answer_profile_recall"
    },
    {
      "id": "e_rewrite_search",
      "source": "rewrite_followup_query",
      "target": "search_knowledge"
    },
    {
      "id": "e_direct_search",
      "source": "set_direct_query",
      "target": "search_knowledge"
    },
    {
      "id": "e_search_check",
      "source": "search_knowledge",
      "target": "check_context"
    },
    {
      "id": "e_context_valid",
      "source": "check_context",
      "target": "remember_last_query",
      "sourceHandle": "valid"
    },
    {
      "id": "e_context_invalid",
      "source": "check_context",
      "target": "send_low_context",
      "sourceHandle": "invalid"
    },
    {
      "id": "e_query_question",
      "source": "remember_last_query",
      "target": "remember_last_question"
    },
    {
      "id": "e_question_context",
      "source": "remember_last_question",
      "target": "build_answer_context"
    },
    {
      "id": "e_context_answer",
      "source": "build_answer_context",
      "target": "answer_grounded"
    }
  ],
  "viewport": {
    "x": 0,
    "y": 0,
    "zoom": 0.58
  }
}
